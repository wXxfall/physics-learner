{
  "manifest_version": 3,
  "name": "arXiv Beautifier",
  "version": "1.0.0",
  "description": "美化arXiv网站界面，提供更美观的阅读体验",
  "author": "PhysicsLearner",
  "content_scripts": [
    {
      "matches": ["*://arxiv.org/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab"
  ]
}